{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "TWSE Latest Report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "--top",
        "25",
        "--outdir",
        "output"
      ]
    },
    {
      "name": "TWSE Report With Date",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "--date",
        "20260414",
        "--top",
        "25",
        "--outdir",
        "output"
      ]
    }
  ]
}
